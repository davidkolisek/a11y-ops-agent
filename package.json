{
  "name": "a11y-agent-ops",
  "version": "0.3.1",
  "description": "Framework-independent accessibility auditing CLI for any website or web application",
  "type": "module",
  "bin": {
    "a11y-ops": "./dist/cli/index.js",
    "a11y-agent-ops": "./dist/cli/index.js"
  },
  "main": "./dist/cli/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "accessibility",
    "a11y",
    "axe-core",
    "playwright",
    "cli",
    "wcag",
    "audit"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidkolisek/a11y-agent-ops.git"
  },
  "homepage": "https://github.com/davidkolisek/a11y-agent-ops#readme",
  "bugs": {
    "url": "https://github.com/davidkolisek/a11y-agent-ops/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.10.1",
    "axe-core": "^4.10.3",
    "clipboardy": "^5.3.1",
    "commander": "^13.1.0",
    "jiti": "^2.7.0",
    "open": "^11.0.0",
    "playwright": "^1.51.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.10",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  }
}
