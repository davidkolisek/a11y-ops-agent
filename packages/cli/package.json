{
  "name": "a11y-agent-ops",
  "version": "0.3.4",
  "description": "Framework-independent accessibility auditing CLI for any website or web application",
  "type": "module",
  "bin": {
    "a11y-ops": "./dist/index.js",
    "a11y-agent-ops": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "scripts/postinstall.mjs",
    "vendor"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist vendor",
    "prepack": "node ../../scripts/bundle-workspace-deps.mjs prepack",
    "postpack": "node ../../scripts/bundle-workspace-deps.mjs restore",
    "prepublishOnly": "npm run build -w @a11y-agent-ops/shared && npm run build -w @a11y-agent-ops/engine && npm run build",
    "postinstall": "node ./scripts/postinstall.mjs"
  },
  "keywords": [
    "accessibility",
    "a11y",
    "axe-core",
    "playwright",
    "cli",
    "wcag",
    "audit"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidkolisek/a11y-agent-ops.git"
  },
  "homepage": "https://github.com/davidkolisek/a11y-agent-ops#readme",
  "bugs": {
    "url": "https://github.com/davidkolisek/a11y-agent-ops/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@a11y-agent-ops/engine": "*",
    "@a11y-agent-ops/shared": "*",
    "@axe-core/playwright": "^4.10.1",
    "axe-core": "^4.10.3",
    "clipboardy": "^5.3.1",
    "commander": "^13.1.0",
    "jiti": "^2.7.0",
    "open": "^11.0.0",
    "playwright": "^1.51.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
