  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@a11y-agent-ops/shared": "*",
    "@axe-core/playwright": "^4.10.1",
    "axe-core": "^4.10.3",
    "jiti": "^2.7.0",
    "playwright": "^1.51.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  },
  "private": true
