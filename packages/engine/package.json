{
  "name": "@a11y-agent-ops/engine",
  "version": "0.3.4",
  "description": "Accessibility scanning engine for a11y-agent-ops",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
